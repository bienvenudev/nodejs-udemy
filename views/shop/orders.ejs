<%- include('../includes/head.ejs') %>
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if(orders.length <= 0) { %>
                <h1>No order yet!</h1>
            <% } else {%>
                <ul class="orders__item-list">
                    <% orders.forEach(order => { %>
                        <li class="orders__item">
                            <h1># <%= order.id %></h1>
                            <h2>Products:</h2>
                            <ul>
                                <% order.products.forEach(product => { %>
                                    <li><%= product.title %> (x<%= product.orderItem.quantity %>)</li>
                                <% }) %>
                            </ul>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>